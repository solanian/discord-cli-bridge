FROM node:22-bookworm

# Install Claude Code CLI (required by the SDK internally)
RUN npm install -g @anthropic-ai/claude-code

WORKDIR /app

COPY claude-agent-server/package.json ./
RUN npm install

COPY claude-agent-server/server.js ./

# Run as node user (non-root)
RUN mkdir -p /workspace && chown -R node:node /app /workspace
USER node

EXPOSE 9877 9878

HEALTHCHECK --interval=10s --timeout=3s CMD curl -f http://localhost:9878/healthz || exit 1

CMD ["node", "server.js"]
