FROM node:22-bookworm

RUN npm install -g @openai/codex

# Run as non-root
RUN mkdir -p /workspace && chown -R node:node /workspace
USER node

EXPOSE 9876

# Health check
HEALTHCHECK --interval=10s --timeout=3s CMD curl -f http://localhost:9876/healthz || exit 1

CMD ["codex", "app-server", "--listen", "ws://0.0.0.0:9876"]
